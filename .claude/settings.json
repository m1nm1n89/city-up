{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./.env.*)",
      "Read(./.dev.vars)",
      "Read(./.dev.vars.*)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Read(**/.env.*)",
      "Bash(cat:*./.env*)",
      "Bash(cat:*.env)",
      "Bash(cat:*.env.local)",
      "Bash(head:*./.env*)",
      "Bash(tail:*./.env*)",
      "Bash(grep:*./.env*)",
      "Bash(rg:*./.env*)",
      "Bash(less:*./.env*)",
      "Bash(more:*./.env*)",
      "Bash(awk:*./.env*)",
      "Bash(sed:*./.env*)",
      "Bash(xxd:*./.env*)",
      "Bash(od:*./.env*)"
    ]
  }
}
